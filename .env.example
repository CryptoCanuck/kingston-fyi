# Kingston.FYI — environment contract.
# Copy to .env and fill in. .env is gitignored.

# ---- Core (required) ----
# Postgres + PostGIS connection string.
DATABASE_URI=postgres://kingston:CHANGE_ME@127.0.0.1:5434/kingston_fyi
# Payload encryption secret (openssl rand -hex 32).
PAYLOAD_SECRET=CHANGE_ME
# Public origin used for canonical URLs / hostname→city resolution.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---- Media storage: Cloudflare R2 (S3-compatible) — Epic 1/2 ----
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# ---- Email + newsletter: Resend (CASL) — Epic 5/7 ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Maps + geocoding: MapTiler — Epic 2 ----
NEXT_PUBLIC_MAPTILER_KEY=
MAPTILER_GEOCODING_KEY=

# ---- CAPTCHA: Cloudflare Turnstile — Epic 5 ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Directory seeding: Google Places API (ToS-bounded discovery/refresh) — Epic 2 ----
GOOGLE_PLACES_API_KEY=

# ---- LLM enrichment: self-hosted open-weights endpoint (lib/inference) — Epic 1/2/4 ----
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=

# ---- Observability ----
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---- Monetization ----
NEXT_PUBLIC_ADSENSE_CLIENT=

# ---- Background jobs cron trigger (Payload Jobs Queue) — Epic 1 ----
CRON_SECRET=
