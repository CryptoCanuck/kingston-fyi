# ==============================================
# FYI Multi-City Platform Environment Variables
# ==============================================
# Copy this file to .env and fill in the values
# Run ./scripts/generate-secrets.sh to auto-generate secrets

# ==============================================
# Database Configuration
# ==============================================
# Auto-generated by generate-secrets.sh
POSTGRES_PASSWORD=your_secure_password_here

# ==============================================
# JWT Configuration
# ==============================================
# Auto-generated by generate-secrets.sh
# CRITICAL: Keep these secret!
JWT_SECRET=your_jwt_secret_here_32_bytes_hex
JWT_EXPIRY=3600

# ==============================================
# Supabase API Keys
# ==============================================
# Auto-generated by generate-secrets.sh
# These are JWT tokens with specific claims
ANON_KEY=your_anon_key_jwt_token_here
SERVICE_ROLE_KEY=your_service_role_key_jwt_token_here

# ==============================================
# Site Configuration
# ==============================================
# Update these for your deployment
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
ADDITIONAL_REDIRECT_URLS=

# ==============================================
# Auth Settings
# ==============================================
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

# ==============================================
# SMTP Configuration (Email)
# ==============================================
# For production, use a real SMTP provider
# In development, emails go to Inbucket (http://localhost:9000)
SMTP_ADMIN_EMAIL=admin@localhost
SMTP_HOST=smtp.localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=FYI

# ==============================================
# Redis Configuration
# ==============================================
# Auto-generated by generate-secrets.sh
REDIS_PASSWORD=your_redis_password_here

# ==============================================
# n8n Configuration
# ==============================================
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Toronto
# n8n uses built-in user management (Settings > Users) — no basic auth env vars needed
N8N_DB_PASSWORD=your_n8n_db_password_here

# ==============================================
# Studio Settings (Dev Only)
# ==============================================
# Supabase Studio runs on port 3001 in dev mode
# Access at http://localhost:3001

# ==============================================
# Production Overrides
# ==============================================
# Uncomment and set these for production
# SITE_URL=https://kingston.fyi
# API_EXTERNAL_URL=https://api.kingston.fyi
# ENABLE_EMAIL_AUTOCONFIRM=false
# DISABLE_SIGNUP=false

# ==============================================
# Meilisearch Configuration
# ==============================================
MEILI_MASTER_KEY=your_meilisearch_master_key_here

# ==============================================
# LM Studio Configuration
# ==============================================
# 5090 GPU rig — real-time inference (moderation, search assist)
LM_STUDIO_FAST_URL=http://gpu-rig:1234
# gmktec boxes — batch inference (enrichment, summarization)
LM_STUDIO_BATCH_URL=http://gmktec-1:1234
# Embedding endpoint
LM_STUDIO_EMBED_URL=http://gmktec-1:1234

# ==============================================
# Notes
# ==============================================
# - Never commit this file to git (it's in .gitignore)
# - Rotate secrets if compromised
# - Use strong passwords (32+ characters)
# - ANON_KEY is safe to expose client-side
# - SERVICE_ROLE_KEY must stay server-side only
